{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch in Firefox",
      "type": "firefox",
      "request": "launch",
      "url": "http://localhost:5500",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "Start Live Server",
      "postDebugTask": "Stop Live Server",
      "reAttach": true,
      "pathMappings": [
        {
          "url": "http://localhost:5500",
          "path": "${workspaceFolder}"
        }
      ]
    }
  ]
}